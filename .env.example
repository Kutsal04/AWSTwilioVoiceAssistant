ENV_NAME=local
PUBLIC_BASE_URL=http://localhost:8080
DEFAULT_PERSONA_ID=warm_clinical_followup
PERSONA_LOOKUP_TIMEOUT_SECONDS=2
PERSONA_LOOKUP_FALLBACK_ENABLED=true
VERIFY_TWILIO_SIGNATURE=false
TWILIO_AUTH_TOKEN=
MEDIA_IDLE_TIMEOUT_SECONDS=30
AUDIO_QUEUE_MAXSIZE=50
NOVA_STREAM_OPEN_TIMEOUT_SECONDS=20
NOVA_RESPONSE_TIMEOUT_SECONDS=30
GRACEFUL_SHUTDOWN_DRAIN_SECONDS=5
SESSION_WRITE_TIMEOUT_SECONDS=2
SESSION_WRITE_RETRY_DELAY_SECONDS=0.1
SESSION_CREATE_MAX_ATTEMPTS=3
SESSION_UPDATE_MAX_ATTEMPTS=2
SESSION_FINALIZE_MAX_ATTEMPTS=5
TRANSCRIPT_WRITE_TIMEOUT_SECONDS=1
TRANSCRIPT_WRITE_RETRY_DELAY_SECONDS=0.1
TRANSCRIPT_WRITE_MAX_ATTEMPTS=2
SESSIONS_TABLE_NAME=sessions
PERSONAS_TABLE_NAME=personas
TRANSCRIPT_TURNS_TABLE_NAME=transcript_turns
BEDROCK_REGION=us-east-1
NOVA_MODEL_ID=amazon.nova-2-sonic-v1:0
